{
  "name": "shell-kit",
  "version": "0.84.0",
  "type": "module",
  "description": "Geteilte Shell-Bausteine — die EINZIGE Quelle der Wahrheit fuers Shell-Paket. app/ reist per Rep, launcher/ bleibt our-side. Konsumiert per git-Tag von Editor (Shell-Studio) und Runtime.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./app": {
      "types": "./dist/app/index.d.ts",
      "import": "./dist/app/index.js"
    },
    "./cluster": {
      "types": "./dist/cluster.d.ts",
      "import": "./dist/cluster.js"
    },
    "./mesh": {
      "types": "./dist/mesh.d.ts",
      "import": "./dist/mesh.js"
    },
    "./route": {
      "types": "./dist/route.d.ts",
      "import": "./dist/route.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "peerDependencies": {
    "react": ">=18",
    "leaflet": ">=1.9"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/react": "^18.3.3",
    "react": "^18.3.1",
    "leaflet": "^1.9.4",
    "@types/leaflet": "^1.9.12"
  }
}
